    stripe_status_update: async (req, res) => {
        try {
            const { transation_id } = req.body;

            if (!transation_id) {
                return helper.error(res, "Transaction ID is required.");
            }

            const transaction = await db.transactions.findOne({
                where: { trasaction_id: transation_id },
                raw: true,
            });

            if (!transaction) {
                return helper.error(res, "Transaction not found.");
            }

            if (transaction.payment_status === "1") {
                return helper.success(res, "Payment already processed.");
            }

            await db.transactions.update(
                { payment_status: "1" },
                { where: { id: transaction.id } }
            );

            const bookingId = transaction.booking_id;

            if (!bookingId) {
                return helper.error(res, "Associated booking not found in transaction.");
            }

            await db.booking.update(
                {
                    payment_status: "1",
                    payment_method: "1",
                    status: "4",
                },
                { where: { id: bookingId } }
            );

            const booking = await db.booking.findOne({
                where: { id: bookingId },
                include: [
                    {
                        model: db.services,
                        as: 'servicesssss'
                    },
                ],
            });

            if (!booking) {
                return helper.error(res, "Booking not found after update.");
            }

            const user = await db.users.findOne({
                where: { id: booking.user_id },
                attributes: ['id', 'device_token', 'first_name', 'last_name', 'image', 'is_notification'],
            });

            const provider = await db.users.findOne({
                where: { id: booking.provider_id },
                attributes: ['id', 'device_token', 'first_name', 'last_name', 'image', 'is_notification'],
            });

            const serviceTitle = booking.servicesssss?.service_title || "Service";

            await db.notifications.create({
                sender_id: req.user.id,
                receiver_id: booking.provider_id,
                type: 8,
                request_id: booking.id,
                title: `Booking Confirmed: ${serviceTitle}`,
                message: `${user.first_name} ${user.last_name} completed the payment. Booking confirmed.`,
                sender_first_name: req.user.first_name,
                sender_last_name: req.user.last_name,
                sender_image: req.user.image,
            });

            if (provider?.device_token && provider?.is_notification == "1") {
                await helper.sendPushNotification(
                    provider.device_token,
                    {
                        sender_id: user.id,
                        sender_first_name: user.first_name,
                        sender_last_name: user.last_name,
                        sender_image: user.image,
                        title: `Booking Confirmed: ${serviceTitle}`,
                        message:`${user.first_name} ${user.last_name} completed the payment. Booking confirmed.`,
                        type: 8,
                        booking_id: booking.id || 0,
                    },
                    1
                );
            }

            return helper.success(res, "Payment processed and provider notified.");
        } catch (error) {
            console.error("Stripe Status Update Error:", error);
            return helper.error(res, "Something went wrong.", error);
        }
    },


